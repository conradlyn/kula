 	}
 	return host
 }
+func (s *Server) handleIndex(w http.ResponseWriter, r *http.Request) {
+	if r.URL.Path != "/" && r.URL.Path != "/index.html" {
+		// Fallback to static files for other paths
+		staticContent, _ := fs.Sub(staticFS, "static")
+		http.FileServer(http.FS(staticContent)).ServeHTTP(w, r)
+		return
+	}
+	s.renderTemplate(w, r, "static/index.html")
+}
+
+func (s *Server) handleGame(w http.ResponseWriter, r *http.Request) {
+	s.renderTemplate(w, r, "static/game.html")
+}
+
+func (s *Server) renderTemplate(w http.ResponseWriter, r *http.Request, templatePath string) {
+	nonce, ok := r.Context().Value(nonceKey).(string)
+	if !ok {
+		http.Error(w, "internal server error", http.StatusInternalServerError)
+		return
+	}
+
+	content, err := staticFS.ReadFile(templatePath)
+	if err != nil {
+		http.Error(w, "not found", http.StatusNotFound)
+		return
+	}
+
+	tmpl, err := template.New(templatePath).Parse(string(content))
+	if err != nil {
+		http.Error(w, "internal server error", http.StatusInternalServerError)
+		return
+	}
+
+	data := struct {
+		Nonce string
+	}{
+		Nonce: nonce,
+	}
+
+	w.Header().Set("Content-Type", "text/html; charset=utf-8")
+	if err := tmpl.Execute(w, data); err != nil {
+		log.Printf("Template execution error: %v", err)
+	}
+}
